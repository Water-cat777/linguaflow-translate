{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/workbench.html", "destination": "/workbench.html" },
    { "source": "/subtitle.html", "destination": "/subtitle.html" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" }
  ]
}
